{
  "repo": "plume-dev-formatter-meter",
  "language": "Rust",
  "category": "Developer tools",
  "goal": "Build a Rust toolkit that studies formatter behavior through framed sample traffic, with bounds and ordering tests and no network dependency.",
  "review_model": {
    "terms": [
      "change width",
      "diagnostic quality",
      "review cost",
      "safe rewrite"
